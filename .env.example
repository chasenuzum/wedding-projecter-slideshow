# Omaha-88 configuration. Copy to `.env` and edit. All vars are prefixed OMAHA_.

# --- Event identity ---
OMAHA_EVENT_NAME="Kat & Chase"
OMAHA_EVENT_DATE=2026-08-08
OMAHA_VENUE="Leo Ballroom, Omaha"
OMAHA_PUBLIC_DOMAIN=https://katandchase2026.com

# --- Server ---
OMAHA_HOST=0.0.0.0
OMAHA_PORT=8000

# --- Moderation: local Moondream 3 (primary) ---
# Photon model NAME (not an HF repo id; a "/" is read as a fine-tune adapter).
# Weights are fetched/cached by the moondream runtime on first run.
OMAHA_MODEL_ID=moondream3-preview
OMAHA_WORKER_COUNT=1

# Dedicated NSFW classifier (the reliable nudity gate, runs before Moondream).
# Swap the model freely; raise the threshold if benign skin (swimwear) is held,
# lower it if something slips through.
OMAHA_NSFW_MODEL_ID=Marqo/nsfw-image-detection-384
OMAHA_NSFW_THRESHOLD=0.5

# --- Moderation: OpenRouter Gemini Flash (cloud fallback) ---
# Used only when the local model is unavailable. Leave the key blank to disable
# the fallback (uncovered photos then hold in the review queue).
OMAHA_OPENROUTER_API_KEY=
OMAHA_OPENROUTER_MODEL=google/gemini-2.5-flash
OMAHA_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Admin review dashboard ---
# Token required to view /admin and approve/reject held photos. CHANGE THIS.
OMAHA_ADMIN_TOKEN=change-me-before-the-wedding

# --- Object storage: the PRIMARY photo store (S3-compatible, REQUIRED) ---
# ALL photos live here. The endpoint is the ACCOUNT endpoint only (the bucket is
# separate, not part of the URL).
#
# Cloudflare R2 (recommended — off-machine, no egress fees):
#   OMAHA_ARCHIVE_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
#   OMAHA_ARCHIVE_REGION=auto
#   keys from: R2 -> Manage R2 API Tokens -> Object Read & Write
# MinIO (self-hosted, docker compose up -d):
#   OMAHA_ARCHIVE_ENDPOINT_URL=http://localhost:9000
#   OMAHA_ARCHIVE_REGION=us-east-1   (creds minioadmin/minioadmin)
OMAHA_ARCHIVE_BUCKET=
OMAHA_ARCHIVE_ENDPOINT_URL=
OMAHA_ARCHIVE_REGION=auto
OMAHA_ARCHIVE_ACCESS_KEY_ID=
OMAHA_ARCHIVE_SECRET_ACCESS_KEY=
# Optional download-filename prefix; defaults to a slug of OMAHA_EVENT_NAME.
OMAHA_ARCHIVE_PREFIX=
