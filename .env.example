# Live Wedding Slideshow configuration. Copy to `.env` and edit. Vars prefixed SLIDESHOW_.

# --- Event identity (shown on the upload/projector/gallery screens) ---
SLIDESHOW_EVENT_NAME="Alex & Sam"
SLIDESHOW_EVENT_DATE=2026-06-20
SLIDESHOW_VENUE="The Grand Hall"
SLIDESHOW_PUBLIC_DOMAIN=https://your-domain.com

# --- Server ---
SLIDESHOW_HOST=0.0.0.0
SLIDESHOW_PORT=8000

# --- Moderation: local Moondream 3 (primary) ---
# Photon model NAME (not an HF repo id; a "/" is read as a fine-tune adapter).
# Weights are fetched/cached by the moondream runtime on first run.
SLIDESHOW_MODEL_ID=moondream3-preview
SLIDESHOW_WORKER_COUNT=1

# Dedicated NSFW classifier (the reliable nudity gate, runs before Moondream).
# Swap the model freely; raise the threshold if benign skin (swimwear) is held,
# lower it if something slips through.
SLIDESHOW_NSFW_MODEL_ID=Marqo/nsfw-image-detection-384
SLIDESHOW_NSFW_THRESHOLD=0.5

# --- Moderation: OpenRouter Gemini Flash (cloud fallback) ---
# Used only when the local model is unavailable. Leave the key blank to disable
# the fallback (uncovered photos then hold in the review queue).
SLIDESHOW_OPENROUTER_API_KEY=
SLIDESHOW_OPENROUTER_MODEL=google/gemini-2.5-flash
SLIDESHOW_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Admin review dashboard ---
# Token required to view /admin and approve/reject held photos. CHANGE THIS.
SLIDESHOW_ADMIN_TOKEN=change-me-before-the-wedding

# --- Object storage: the PRIMARY photo store (S3-compatible, REQUIRED) ---
# ALL photos live here. The endpoint is the ACCOUNT endpoint only (the bucket is
# separate, not part of the URL).
#
# Cloudflare R2 (recommended — off-machine, no egress fees):
#   SLIDESHOW_ARCHIVE_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
#   SLIDESHOW_ARCHIVE_REGION=auto
#   keys from: R2 -> Manage R2 API Tokens -> Object Read & Write
# MinIO (self-hosted, docker compose up -d):
#   SLIDESHOW_ARCHIVE_ENDPOINT_URL=http://localhost:9000
#   SLIDESHOW_ARCHIVE_REGION=us-east-1   (creds minioadmin/minioadmin)
SLIDESHOW_ARCHIVE_BUCKET=
SLIDESHOW_ARCHIVE_ENDPOINT_URL=
SLIDESHOW_ARCHIVE_REGION=auto
SLIDESHOW_ARCHIVE_ACCESS_KEY_ID=
SLIDESHOW_ARCHIVE_SECRET_ACCESS_KEY=
# Optional download-filename prefix; defaults to a slug of SLIDESHOW_EVENT_NAME.
SLIDESHOW_ARCHIVE_PREFIX=
